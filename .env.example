# Example environment variables for The Spirited Oracle (project root)
# Copy this to `.env` or to `backend/.env` and fill in real API keys before running.

# --- Backend LLM / TTS keys ---
GEMINI_API_KEY=your_gemini_api_key_here                # Google Gemini API key (or leave empty if using OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here        # OpenRouter API key (optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here        # ElevenLabs TTS API key

# --- Supabase / Database (optional) ---
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# --- Feature toggles (0/1) ---
USE_OPENROUTER=0                   # Set to 1 to route LLM calls through OpenRouter
USE_APARTMENTS_COM=0               # Set to 1 to enable apartments.com scraper (requires Chrome + chromedriver)
USE_MOCK_DATA=1                    # Set to 1 to use local mock data (frontend friendly)
USE_MCP_CLIENT=1                   # MCP server usage: 1 = spawn subprocess, 0 = direct call

# --- Frontend / Vite ---
# Set this to the backend API origin if running backend separately (default: http://localhost:8000)
VITE_API_URL=http://localhost:8000

# --- Notes ---
# - Copy this file to `backend/.env` (or project root `.env`) and populate keys.
# - Do NOT commit real API keys to version control.
# - If you enable `USE_APARTMENTS_COM`, ensure Chrome and chromedriver are installed and accessible.