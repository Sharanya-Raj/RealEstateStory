# Production Environment Configuration
# Copy this file to .env.production and fill in your actual API keys

# ===== REQUIRED: API Keys =====
GEMINI_API_KEY=your_gemini_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ===== REQUIRED: Database =====
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# ===== OPTIONAL: Alternative LLM Provider =====
OPENROUTER_API_KEY=
USE_OPENROUTER=0

# ===== OPTIONAL: Feature Toggles =====
USE_APARTMENTS_COM=0           # Requires Chrome + chromedriver (not recommended for production)
USE_MOCK_DATA=0                # Use real database data in production
USE_MCP_CLIENT=1               # Enable MCP server for agent coordination

# ===== Frontend Configuration =====
# Set this to your backend API URL (use your domain or Vultr IP)
VITE_API_URL=http://YOUR_VULTR_IP:8000

# ===== Production Settings =====
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# ===== DEPLOYMENT NOTES =====
# 1. Replace YOUR_VULTR_IP with your actual Vultr instance IP address
# 2. After deployment, if using a domain, update VITE_API_URL to https://api.yourdomain.com
# 3. Never commit this file with real API keys to version control
# 4. Keep your .env.production file secure and backed up
