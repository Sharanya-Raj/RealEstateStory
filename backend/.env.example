# Backend API Keys
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
ELEVENLABS_API_KEY=""
SUPABASE_URL=""
SUPABASE_KEY=""

# Feature Toggles
USE_OPENROUTER=0
USE_APARTMENTS_COM=0
USE_MOCK_DATA=1
# test_mcp_client: 1 = spawn MCP subprocess, 0 = call pipeline directly (no MCP server)
USE_MCP_CLIENT=1
# Log to file (test_mcp_client switches to DIRECT mode when set so logs are captured)
# MCP_LOG_FILE=mcp.log
# Batching / speed
# MAX_CSV_LISTINGS=12       — CSV fallback: max listings to analyze
# MAX_SCRAPER_ANALYZE=20    — Real scraper: cap before running agents (keeps demo fast)
# LLM_BATCH_SIZE=8          — Listings per LLM chunk
# LLM_BATCH_DELAY=1.5       — Seconds between LLM chunks
